# Copy this file to .env.local and fill in your key.
# Powers live case generation (app/api/generate-case) via Groq's OpenAI-compatible API.
GROQ_API_KEY=

# Optional — defaults to llama-3.3-70b-versatile.
# GROQ_MODEL=llama-3.3-70b-versatile

# Optional — only needed if the Python multi-agent backend (uvicorn api.main:app)
# runs somewhere other than http://localhost:8000.
# NEXT_PUBLIC_API_URL=http://localhost:8000
