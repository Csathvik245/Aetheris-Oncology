# Copy this file to .env (repo root) and fill in your key(s).
# Powers the Python multi-agent backend (agents/, api/main.py, mcp_servers/).

# Required for real LLM output from every agent (genomic, literature, outcome,
# trial, toxicity, orchestrator all run on Groq). Without it, agents fall back
# to deterministic offline text instead of crashing (see agents/llm.py).
GROQ_API_KEY=

# Optional — unlocks fuller OncoKB annotation data. Without it, mcp_servers/
# oncokb_server.py still works via its public-tier/offline fallback.
ONCOKB_API_KEY=

# Not currently used by any code path (leftover from an earlier draft of the
# spec before the backend was refactored to run entirely on Groq). Safe to
# leave blank.
# ANTHROPIC_API_KEY=
# HUGGINGFACE_TOKEN=
